{
  "name": "oneway-gateway-monorepo",
  "version": "1.0.0",
  "description": "oneway monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "lint": "pnpm --parallel lint",
    "linter": "eslint",
    "full-ci": "pnpm --filter backend test:cov",
    "cov:merge": "istanbul-merge --out coverage/report/coverage-final.json apps/**/coverage/**/coverage-final.json packages/**/coverage/**/coverage-final.json && NYC_TEMP_DIR=coverage/report nyc report --reporter=html --reporter=text --reporter=lcov --temp-directory=coverage/report --report-dir=coverage/report"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.3.0",
    "@types/node": "^24.10.14",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-istanbul": "4.0.18",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.3.0",
    "istanbul-merge": "^2.0.0",
    "nyc": "^18.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.4.0"
  }
}